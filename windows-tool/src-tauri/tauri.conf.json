{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TanaoroshiShukeiTool",
  "version": "0.1.0",
  "identifier": "com.warehouse.tanaoroshi",
  "build": {
    "beforeBuildCommand": "node copy-html.js",
    "beforeDevCommand": "node copy-html.js",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "棚卸集計ツール",
        "width": 1000,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ]
  }
}
